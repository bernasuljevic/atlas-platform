<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Atlas.Modules.Auth.Api</RootNamespace>
  </PropertyGroup>

  <!-- Bu proje bir "Web" projesi değil, sıradan bir class library.
